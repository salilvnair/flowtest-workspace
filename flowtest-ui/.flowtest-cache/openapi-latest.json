{
  "project": {
    "name": "Zapper Electricity Disconnect",
    "type": "simulation",
    "customer": "UPS",
    "sites": [
      {
        "siteId": "UPS-TX-001",
        "state": "TX",
        "city": "Dallas"
      },
      {
        "siteId": "UPS-NJ-002",
        "state": "NJ",
        "city": "Newark"
      }
    ]
  },
  "apis": [
    {
      "apiId": "API1",
      "name": "AddressValidation",
      "method": "POST",
      "path": "/address/validate",
      "syncAsync": "SYNC",
      "slaSeconds": 2,
      "purpose": "Validate customer site addresses",
      "request": {
        "type": "object",
        "required": [
          "customerType",
          "customerName",
          "requestType",
          "sites"
        ],
        "properties": {
          "customerType": {
            "type": "string",
            "enum": [
              "ENTERPRISE"
            ]
          },
          "customerName": {
            "type": "string"
          },
          "requestType": {
            "type": "string",
            "enum": [
              "DISCONNECT"
            ]
          },
          "sites": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "siteId",
                "state",
                "city",
                "zip",
                "addressLine1"
              ],
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "state": {
                  "type": "string"
                },
                "city": {
                  "type": "string"
                },
                "zip": {
                  "type": "string"
                },
                "addressLine1": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "responses": {
        "success": {
          "type": "object",
          "required": [
            "status",
            "validatedSites"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "VALIDATED"
              ]
            },
            "validatedSites": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "siteId",
                  "isValid",
                  "normalizedAddress"
                ],
                "properties": {
                  "siteId": {
                    "type": "string"
                  },
                  "isValid": {
                    "type": "boolean"
                  },
                  "normalizedAddress": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "failures": [
          {
            "status": "REJECTED",
            "errorCode": "ADDR_MISMATCH",
            "message": "Address mismatch for one or more sites",
            "validatedSites": [
              {
                "siteId": "UPS-TX-001",
                "isValid": true,
                "normalizedAddress": "1200 LOGISTICS PKWY, DALLAS, TX 75001"
              },
              {
                "siteId": "UPS-NJ-002",
                "isValid": false,
                "reason": "ZIP_CITY_STATE_MISMATCH",
                "normalizedAddress": "900 DISTRIBUTION AVE, NEWARK, NJ 07103"
              }
            ]
          }
        ]
      }
    },
    {
      "apiId": "API2",
      "name": "InventoryValidation",
      "method": "POST",
      "path": "/inventory/validate",
      "syncAsync": "SYNC",
      "slaSeconds": 2,
      "purpose": "Validate transformer and connection existence",
      "request": {
        "type": "object",
        "required": [
          "sites"
        ],
        "properties": {
          "sites": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "siteId",
                "transformerId",
                "connectionId"
              ],
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "transformerId": {
                  "type": "string"
                },
                "connectionId": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "responses": {
        "success": {
          "type": "object",
          "required": [
            "status",
            "inventoryChecks"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "OK"
              ]
            },
            "inventoryChecks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "siteId",
                  "transformerExists",
                  "connectionExists",
                  "feeder"
                ],
                "properties": {
                  "siteId": {
                    "type": "string"
                  },
                  "transformerExists": {
                    "type": "boolean"
                  },
                  "connectionExists": {
                    "type": "boolean"
                  },
                  "feeder": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "failures": [
          {
            "status": "FAILED",
            "errorCode": "INVENTORY_ASSET_NOT_FOUND",
            "inventoryChecks": [
              {
                "siteId": "UPS-TX-001",
                "transformerExists": true,
                "connectionExists": false,
                "missingField": "connectionId",
                "providedConnectionId": "CN-TX-7788"
              },
              {
                "siteId": "UPS-NJ-002",
                "transformerExists": false,
                "connectionExists": true,
                "missingField": "transformerId",
                "providedTransformerId": "TR-NJ-3344"
              }
            ]
          }
        ]
      }
    },
    {
      "apiId": "API3",
      "name": "GetPendingBills",
      "method": "POST",
      "path": "/billing/pending",
      "syncAsync": "SYNC",
      "slaSeconds": 3,
      "purpose": "Check pending bills before disconnect",
      "request": {
        "type": "object",
        "required": [
          "customerAccountId",
          "sites"
        ],
        "properties": {
          "customerAccountId": {
            "type": "string"
          },
          "sites": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "siteId",
                "connectionId"
              ],
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "connectionId": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "responses": {
        "success": {
          "type": "object",
          "required": [
            "status",
            "pendingBills"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "CLEAR"
              ]
            },
            "pendingBills": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "siteId",
                  "amount",
                  "currency"
                ],
                "properties": {
                  "siteId": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "failures": [
          {
            "status": "BLOCKED",
            "errorCode": "PENDING_BILLS_FOUND",
            "pendingBills": [
              {
                "siteId": "UPS-TX-001",
                "amount": 12540.75,
                "currency": "USD",
                "agingDays": 43
              },
              {
                "siteId": "UPS-NJ-002",
                "amount": 2300,
                "currency": "USD",
                "agingDays": 12
              }
            ],
            "actionRequired": "CLEAR_DUES_BEFORE_DISCONNECT"
          }
        ]
      }
    },
    {
      "apiId": "API4",
      "name": "SubmitDisconnectRequest",
      "method": "POST",
      "path": "/disconnect/submit",
      "syncAsync": "SYNC",
      "slaSeconds": 4,
      "purpose": "Submit disconnect request and receive tracking ids",
      "request": {
        "type": "object",
        "required": [
          "requestType",
          "requestedBy",
          "sites"
        ],
        "properties": {
          "requestType": {
            "type": "string",
            "enum": [
              "DISCONNECT"
            ]
          },
          "requestedBy": {
            "type": "string"
          },
          "sites": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "siteId",
                "connectionId",
                "transformerId"
              ],
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "connectionId": {
                  "type": "string"
                },
                "transformerId": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "responses": {
        "success": {
          "type": "object",
          "required": [
            "status",
            "transactionId",
            "correlationId",
            "estimatedCompletionMinutes"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "ACCEPTED"
              ]
            },
            "transactionId": {
              "type": "string"
            },
            "correlationId": {
              "type": "string"
            },
            "estimatedCompletionMinutes": {
              "type": "integer"
            }
          }
        },
        "failures": [
          {
            "status": "CONFLICT",
            "errorCode": "DUPLICATE_DISCONNECT_REQUEST",
            "message": "An active disconnect request already exists for one or more sites",
            "existingTransactionId": "TXN-2026-0401-00991",
            "existingCorrelationId": "CORR-ACTIVE-UPS-DISC",
            "retryAfterSeconds": 1800
          },
          {
            "status": "REJECTED",
            "errorCode": "PRECHECK_FAILED",
            "message": "Disconnect request rejected due to unresolved pre-check failures",
            "failedChecks": [
              "address_validation",
              "pending_bills"
            ],
            "transactionId": null,
            "correlationId": null
          }
        ]
      }
    },
    {
      "apiId": "API5",
      "name": "DisconnectOrderCallback",
      "method": "POST",
      "path": "/callbacks/disconnect-order",
      "syncAsync": "ASYNC",
      "slaSeconds": 30,
      "purpose": "Async callback with disconnect order number",
      "request": {
        "type": "object",
        "required": [
          "eventType",
          "transactionId",
          "correlationId"
        ],
        "properties": {
          "eventType": {
            "type": "string",
            "enum": [
              "DISCONNECT_ORDER_CREATED"
            ]
          },
          "transactionId": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "disconnectOrderNumber": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "responses": {
        "success": {
          "type": "object",
          "required": [
            "status",
            "receivedAt"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "ACKNOWLEDGED"
              ]
            },
            "receivedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "failures": [
          {
            "status": "REJECTED",
            "errorCode": "UNKNOWN_CORRELATION_ID",
            "message": "Correlation ID not found in active disconnect workflow",
            "receivedAt": "2026-04-02T15:30:01Z"
          }
        ]
      }
    },
    {
      "apiId": "API6",
      "name": "SoftDisconnectEvent",
      "method": "POST",
      "path": "/events/disconnect-status",
      "syncAsync": "ASYNC",
      "slaSeconds": 30,
      "purpose": "Async progress event #1",
      "request": {
        "type": "object",
        "required": [
          "correlationId",
          "eventType"
        ],
        "properties": {
          "correlationId": {
            "type": "string"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "SOFT_DISCONNECT_DONE"
            ]
          }
        }
      }
    },
    {
      "apiId": "API7",
      "name": "RippedOffWiresEvent",
      "method": "POST",
      "path": "/events/disconnect-status",
      "syncAsync": "ASYNC",
      "slaSeconds": 30,
      "purpose": "Async progress event #2",
      "request": {
        "type": "object",
        "required": [
          "correlationId",
          "eventType"
        ],
        "properties": {
          "correlationId": {
            "type": "string"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "RIPPED_OFF_WIRES"
            ]
          }
        }
      }
    },
    {
      "apiId": "API8",
      "name": "HardDisconnectEvent",
      "method": "POST",
      "path": "/events/disconnect-status",
      "syncAsync": "ASYNC",
      "slaSeconds": 30,
      "purpose": "Async progress event #3 final",
      "request": {
        "type": "object",
        "required": [
          "correlationId",
          "eventType"
        ],
        "properties": {
          "correlationId": {
            "type": "string"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "HARD_DISCONNECT_DONE"
            ]
          }
        }
      }
    }
  ],
  "asyncWorkflow": {
    "correlationIdRequired": true,
    "eventOrder": [
      "SOFT_DISCONNECT_DONE",
      "RIPPED_OFF_WIRES",
      "HARD_DISCONNECT_DONE"
    ],
    "validationRules": [
      "events must be processed in order",
      "duplicate callbacks/events must be retry-safe",
      "final hard disconnect event is mandatory",
      "unknown correlationId must be rejected"
    ],
    "failureCodes": [
      "UNKNOWN_CORRELATION_ID",
      "EVENT_SEQUENCE_INVALID",
      "HARD_DISCONNECT_EVENT_MISSING"
    ]
  }
}