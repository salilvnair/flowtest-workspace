{
  "project": "Zapper Electricity Disconnect",
  "version": "1.0.0",
  "basePath": "/",
  "apis": [
    {
      "apiId": "API1",
      "name": "AddressValidation",
      "method": "POST",
      "path": "/address/validate",
      "purpose": "Validate customer site addresses",
      "request": {
        "type": "object",
        "properties": {
          "customerType": {
            "type": "string"
          },
          "customerName": {
            "type": "string"
          },
          "requestType": {
            "type": "string"
          },
          "sites": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "state": {
                  "type": "string"
                },
                "city": {
                  "type": "string"
                },
                "zip": {
                  "type": "string"
                },
                "addressLine1": {
                  "type": "string"
                }
              },
              "required": [
                "siteId",
                "state",
                "city",
                "zip",
                "addressLine1"
              ]
            }
          }
        },
        "required": [
          "customerType",
          "customerName",
          "requestType",
          "sites"
        ]
      },
      "responses": [
        {
          "name": "SUCCESS",
          "httpStatus": 200,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "validatedSites": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "siteId": {
                      "type": "string"
                    },
                    "isValid": {
                      "type": "boolean"
                    },
                    "normalizedAddress": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "siteId",
                    "isValid",
                    "normalizedAddress"
                  ]
                }
              }
            },
            "required": [
              "status",
              "validatedSites"
            ]
          },
          "sample": {
            "status": "VALIDATED",
            "validatedSites": [
              {
                "siteId": "UPS-TX-001",
                "isValid": true,
                "normalizedAddress": "1200 LOGISTICS PKWY, DALLAS, TX 75001"
              },
              {
                "siteId": "UPS-NJ-002",
                "isValid": true,
                "normalizedAddress": "900 DISTRIBUTION AVE, NEWARK, NJ 07102"
              }
            ]
          }
        },
        {
          "name": "ADDR_MISMATCH",
          "httpStatus": 400,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "errorCode": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "validatedSites": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "siteId": {
                      "type": "string"
                    },
                    "isValid": {
                      "type": "boolean"
                    },
                    "reason": {
                      "type": "string"
                    },
                    "normalizedAddress": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "siteId",
                    "isValid",
                    "normalizedAddress"
                  ]
                }
              }
            },
            "required": [
              "status",
              "errorCode",
              "message",
              "validatedSites"
            ]
          },
          "sample": {
            "status": "REJECTED",
            "errorCode": "ADDR_MISMATCH",
            "message": "Address mismatch for one or more sites",
            "validatedSites": [
              {
                "siteId": "UPS-TX-001",
                "isValid": true,
                "normalizedAddress": "1200 LOGISTICS PKWY, DALLAS, TX 75001"
              },
              {
                "siteId": "UPS-NJ-002",
                "isValid": false,
                "reason": "ZIP_CITY_STATE_MISMATCH",
                "normalizedAddress": "900 DISTRIBUTION AVE, NEWARK, NJ 07103"
              }
            ]
          }
        }
      ]
    },
    {
      "apiId": "API2",
      "name": "InventoryValidation",
      "method": "POST",
      "path": "/inventory/validate",
      "purpose": "Validate transformer and connection existence",
      "request": {
        "type": "object",
        "properties": {
          "sites": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "transformerId": {
                  "type": "string"
                },
                "connectionId": {
                  "type": "string"
                }
              },
              "required": [
                "siteId",
                "transformerId",
                "connectionId"
              ]
            }
          }
        },
        "required": [
          "sites"
        ]
      },
      "responses": [
        {
          "name": "SUCCESS",
          "httpStatus": 200,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "inventoryChecks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "siteId": {
                      "type": "string"
                    },
                    "transformerExists": {
                      "type": "boolean"
                    },
                    "connectionExists": {
                      "type": "boolean"
                    },
                    "feeder": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "siteId",
                    "transformerExists",
                    "connectionExists",
                    "feeder"
                  ]
                }
              }
            },
            "required": [
              "status",
              "inventoryChecks"
            ]
          },
          "sample": {
            "status": "OK",
            "inventoryChecks": [
              {
                "siteId": "UPS-TX-001",
                "transformerExists": true,
                "connectionExists": true,
                "feeder": "FD-TX-17"
              },
              {
                "siteId": "UPS-NJ-002",
                "transformerExists": true,
                "connectionExists": true,
                "feeder": "FD-NJ-04"
              }
            ]
          }
        },
        {
          "name": "INVENTORY_ASSET_NOT_FOUND",
          "httpStatus": 400,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "errorCode": {
                "type": "string"
              },
              "inventoryChecks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "siteId": {
                      "type": "string"
                    },
                    "transformerExists": {
                      "type": "boolean"
                    },
                    "connectionExists": {
                      "type": "boolean"
                    },
                    "missingField": {
                      "type": "string"
                    },
                    "providedConnectionId": {
                      "type": "string"
                    },
                    "providedTransformerId": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "siteId",
                    "transformerExists",
                    "connectionExists"
                  ]
                }
              }
            },
            "required": [
              "status",
              "errorCode",
              "inventoryChecks"
            ]
          },
          "sample": {
            "status": "FAILED",
            "errorCode": "INVENTORY_ASSET_NOT_FOUND",
            "inventoryChecks": [
              {
                "siteId": "UPS-TX-001",
                "transformerExists": true,
                "connectionExists": false,
                "missingField": "connectionId",
                "providedConnectionId": "CN-TX-7788"
              },
              {
                "siteId": "UPS-NJ-002",
                "transformerExists": false,
                "connectionExists": true,
                "missingField": "transformerId",
                "providedTransformerId": "TR-NJ-3344"
              }
            ]
          }
        }
      ]
    },
    {
      "apiId": "API3",
      "name": "GetPendingBills",
      "method": "POST",
      "path": "/billing/pending",
      "purpose": "Check pending bills before disconnect",
      "request": {
        "type": "object",
        "properties": {
          "customerAccountId": {
            "type": "string"
          },
          "sites": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "connectionId": {
                  "type": "string"
                }
              },
              "required": [
                "siteId",
                "connectionId"
              ]
            }
          }
        },
        "required": [
          "customerAccountId",
          "sites"
        ]
      },
      "responses": [
        {
          "name": "SUCCESS",
          "httpStatus": 200,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "pendingBills": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "siteId": {
                      "type": "string"
                    },
                    "amount": {
                      "type": "number"
                    },
                    "currency": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "siteId",
                    "amount",
                    "currency"
                  ]
                }
              }
            },
            "required": [
              "status",
              "pendingBills"
            ]
          },
          "sample": {
            "status": "CLEAR",
            "pendingBills": [
              {
                "siteId": "UPS-TX-001",
                "amount": 0,
                "currency": "USD"
              },
              {
                "siteId": "UPS-NJ-002",
                "amount": 0,
                "currency": "USD"
              }
            ]
          }
        },
        {
          "name": "PENDING_BILLS_FOUND",
          "httpStatus": 400,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "errorCode": {
                "type": "string"
              },
              "pendingBills": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "siteId": {
                      "type": "string"
                    },
                    "amount": {
                      "type": "number"
                    },
                    "currency": {
                      "type": "string"
                    },
                    "agingDays": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "siteId",
                    "amount",
                    "currency"
                  ]
                }
              },
              "actionRequired": {
                "type": "string"
              }
            },
            "required": [
              "status",
              "errorCode",
              "pendingBills",
              "actionRequired"
            ]
          },
          "sample": {
            "status": "BLOCKED",
            "errorCode": "PENDING_BILLS_FOUND",
            "pendingBills": [
              {
                "siteId": "UPS-TX-001",
                "amount": 12540.75,
                "currency": "USD",
                "agingDays": 43
              },
              {
                "siteId": "UPS-NJ-002",
                "amount": 2300,
                "currency": "USD",
                "agingDays": 12
              }
            ],
            "actionRequired": "CLEAR_DUES_BEFORE_DISCONNECT"
          }
        }
      ]
    },
    {
      "apiId": "API4",
      "name": "SubmitDisconnectRequest",
      "method": "POST",
      "path": "/disconnect/submit",
      "purpose": "Submit disconnect request and receive tracking ids",
      "request": {
        "type": "object",
        "properties": {
          "requestType": {
            "type": "string"
          },
          "requestedBy": {
            "type": "string"
          },
          "sites": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "siteId": {
                  "type": "string"
                },
                "connectionId": {
                  "type": "string"
                },
                "transformerId": {
                  "type": "string"
                }
              },
              "required": [
                "siteId",
                "connectionId",
                "transformerId"
              ]
            }
          }
        },
        "required": [
          "requestType",
          "requestedBy",
          "sites"
        ]
      },
      "responses": [
        {
          "name": "SUCCESS",
          "httpStatus": 200,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "transactionId": {
                "type": "string"
              },
              "correlationId": {
                "type": "string"
              },
              "estimatedCompletionMinutes": {
                "type": "integer"
              }
            },
            "required": [
              "status",
              "transactionId",
              "correlationId",
              "estimatedCompletionMinutes"
            ]
          },
          "sample": {
            "status": "ACCEPTED",
            "transactionId": "TXN-2026-0402-00091",
            "correlationId": "CORR-59A1F0B8-UPS-DISC",
            "estimatedCompletionMinutes": 90
          }
        },
        {
          "name": "DUPLICATE_DISCONNECT_REQUEST",
          "httpStatus": 409,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "errorCode": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "existingTransactionId": {
                "type": "string"
              },
              "existingCorrelationId": {
                "type": "string"
              },
              "retryAfterSeconds": {
                "type": "integer"
              }
            },
            "required": [
              "status",
              "errorCode",
              "message",
              "existingTransactionId",
              "existingCorrelationId",
              "retryAfterSeconds"
            ]
          },
          "sample": {
            "status": "CONFLICT",
            "errorCode": "DUPLICATE_DISCONNECT_REQUEST",
            "message": "An active disconnect request already exists for one or more sites",
            "existingTransactionId": "TXN-2026-0401-00991",
            "existingCorrelationId": "CORR-ACTIVE-UPS-DISC",
            "retryAfterSeconds": 1800
          }
        },
        {
          "name": "PRECHECK_FAILED",
          "httpStatus": 400,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "errorCode": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "failedChecks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "transactionId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "correlationId": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "status",
              "errorCode",
              "message",
              "failedChecks",
              "transactionId",
              "correlationId"
            ]
          },
          "sample": {
            "status": "REJECTED",
            "errorCode": "PRECHECK_FAILED",
            "message": "Disconnect request rejected due to unresolved pre-check failures",
            "failedChecks": [
              "address_validation",
              "pending_bills"
            ],
            "transactionId": null,
            "correlationId": null
          }
        }
      ]
    },
    {
      "apiId": "API5",
      "name": "DisconnectOrderCallback",
      "method": "POST",
      "path": "/callbacks/disconnect-order",
      "purpose": "Async callback with disconnect order number",
      "request": {
        "type": "object",
        "properties": {
          "eventType": {
            "type": "string"
          },
          "transactionId": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "disconnectOrderNumber": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "transactionId",
          "correlationId",
          "eventType"
        ]
      },
      "responses": [
        {
          "name": "SUCCESS",
          "httpStatus": 200,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "receivedAt": {
                "type": "string"
              }
            },
            "required": [
              "status",
              "receivedAt"
            ]
          },
          "sample": {
            "status": "ACKNOWLEDGED",
            "receivedAt": "2026-04-02T15:30:01Z"
          }
        },
        {
          "name": "UNKNOWN_CORRELATION_ID",
          "httpStatus": 400,
          "body": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "errorCode": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "receivedAt": {
                "type": "string"
              }
            },
            "required": [
              "status",
              "errorCode",
              "message",
              "receivedAt"
            ]
          },
          "sample": {
            "status": "REJECTED",
            "errorCode": "UNKNOWN_CORRELATION_ID",
            "message": "Correlation ID not found in active disconnect workflow",
            "receivedAt": "2026-04-02T15:30:01Z"
          }
        }
      ]
    }
  ]
}